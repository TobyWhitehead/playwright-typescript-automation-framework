{
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "lib": ["ES2021", "DOM"],
        "types": ["node", "@playwright/test"],
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@pages/*": ["src/pages/*"],
            "@fixtures/*": ["src/fixtures/*"],
            "@utils/*": ["src/utils/*"],
            "@config/*": ["src/config/*"]
        }
    },
    "include": ["src", "tests"],
    "exclude": ["node_modules"]
}